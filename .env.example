# OpenClaw Empire — Environment Variables
# Copy to .env and fill in your values. NEVER commit real values.

# === AI PROVIDERS ===
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# === DISCORD ===
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# === TELEGRAM ===
TELEGRAM_BOT1_TOKEN=
TELEGRAM_BOT2_TOKEN=
TELEGRAM_BOT3_TOKEN=
TELEGRAM_WEBHOOK_URL=

# === SLACK ===
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL=

# === GITHUB ===
GITHUB_TOKEN=
GITHUB_REPO=

# === GOOGLE / YOUTUBE ===
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
YOUTUBE_CHANNEL_ID=

# === DATABASE ===
DATABASE_URL=sqlite:///./data/empire.db

# === SYSTEM ===
HEALTH_PORT=8080
LOG_LEVEL=INFO
ENVIRONMENT=production
