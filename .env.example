# Platform Tokens
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=optional_guild_id_for_sync

TELEGRAM_BOT1_TOKEN=your_telegram_bot1_token_here
TELEGRAM_BOT2_TOKEN=your_telegram_bot2_token_here
TELEGRAM_BOT3_TOKEN=your_telegram_bot3_token_here
TELEGRAM_WEBHOOK_URL=https://your-render-url.onrender.com/telegram

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_CHANNEL=ops

# AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# GitHub
GITHUB_TOKEN=ghp_your_github_pat_here
GITHUB_REPO=your_username/your_repo

# Infrastructure
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-XXXX?key=YYYY
MEMORY_DB=openclaw_memory.db
BROWSER_HEADLESS=true
SCREENSHOT_DIR=/tmp/openclaw_screenshots
HEALTH_PORT=8080
LOG_LEVEL=INFO
