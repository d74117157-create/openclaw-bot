# OpenClaw Superswarm — Full Environment Variables
# NEVER commit this file. Add these to Render Dashboard only.

# ═══════════════════════════════════════════════════════════════
# PLATFORM BOT TOKENS (Required for swarm to boot)
# ═══════════════════════════════════════════════════════════════
DISCORD_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_guild_id
DISCORD_CLIENT_ID=your_discord_oauth_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret

TELEGRAM_BOT1_TOKEN=your_telegram_bot1_token
TELEGRAM_BOT2_TOKEN=your_telegram_bot2_token
TELEGRAM_BOT3_TOKEN=your_telegram_bot3_token
TELEGRAM_BOT_TOKEN_SUPER=your_super_bot_token
TELEGRAM_WEBHOOK_URL=https://your-render-url/telegram

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_CHANNEL=openclaw-ops

# ═══════════════════════════════════════════════════════════════
# AI / LLM APIs
# ═══════════════════════════════════════════════════════════════
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama3-70b-8192
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key

# ═══════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════
# GOOGLE / YOUTUBE OAUTH (For @realhistory-lessons monetization)
# ═══════════════════════════════════════════════════════════════
GOOGLE_API_KEY=AIzaSy-your-google-api-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://openclaw-bot.onrender.com/google/callback
GOOGLE_ACCESS_TOKEN=auto-filled-after-oauth
GOOGLE_REFRESH_TOKEN=auto-filled-after-oauth
YOUTUBE_CHANNEL_ID=UC-your-channel-id

# OAuth Flow: Visit https://openclaw-bot.onrender.com/google/auth
# Authorize → Tokens auto-save to /tmp/google_tokens.json + env vars
# ═══════════════════════════════════════════════════════════════
GOOGLE_API_KEY=AIzaSy-your-google-api-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://openclaw-bot.onrender.com/oauth/callback
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token
YOUTUBE_CHANNEL_ID=UC-your-channel-id

# ═══════════════════════════════════════════════════════════════
# TWITTER / X OAUTH (For cross-platform posting)
# ═══════════════════════════════════════════════════════════════
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ═══════════════════════════════════════════════════════════════
# BINANCE TRADING (Paper mode by default)
# ═══════════════════════════════════════════════════════════════
BINANCE_API_KEY=your_binance_testnet_key
BINANCE_API_SECRET=your_binance_testnet_secret
BINANCE_PAPER=true
TRADE_RISK_PCT=1.0
TRADE_MAX_POSITIONS=3
MAX_DAILY_LOSS_USD=100.0
MAX_DRAWDOWN_PCT=5.0

# ═══════════════════════════════════════════════════════════════
# GITHUB / RENDER / INFRASTRUCTURE
# ═══════════════════════════════════════════════════════════════
GITHUB_TOKEN=ghp_your_github_token
GITHUB_REPO=d74117157-create/openclaw-bot
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-XXXX?key=YYYY

# ═══════════════════════════════════════════════════════════════
# SYSTEM
# ═══════════════════════════════════════════════════════════════
PORT=8000
HEALTH_PORT=8000
MEMORY_DB=./data/swarm_memory.db
BROWSER_HEADLESS=true
SCREENSHOT_DIR=./screenshots
LOG_LEVEL=INFO
TRADING_MODE=paper
