import os, json, requests

GROQ_API_KEY = os.environ.get("GROQ_API_KEY", "")
GROQ_MODEL   = os.environ.get("GROQ_MODEL", "llama3-70b-8192")

AGENT_PERSONAS = {
    "orchestrator": (
        "You are the master orchestrator of the Eonix Digital Empire. "
        "Route tasks, coordinate agents, and ensure the empire runs efficiently. "
        "Think deeply before acting."
    ),
    "script": (
        "You are the Eonix script writer. Specialize in African history, suppressed "
        "civilizations, and diaspora content. Write compelling 5-7 min YouTube scripts "
        "with strong hooks, narrative flow, and CTAs."
    ),
    "seo": (
        "You are the Eonix SEO agent. Generate viral YouTube titles (A/B options), "
        "full descriptions with timestamps, and 20 tags optimized for African history content."
    ),
    "image": (
        "You are the Eonix image prompt agent. Generate 3 detailed Midjourney/DALL-E prompts "
        "for African history thumbnails — cinematic, dramatic lighting, photorealistic."
    ),
    "research": (
        "You are the Eonix research agent. Synthesize deep historical facts about African "
        "civilizations, diaspora movements, and suppressed history. Cite specific dates, "
        "names, and events."
    ),
    "reply": (
        "You are the Eonix community agent. Write 5 engaging YouTube comments/replies "
        "that spark conversation, seed curiosity, and drive engagement for African history content."
    ),
}

ORCHESTRATOR_SYSTEM = """You are the Eonix task planner. 
Given a task, decompose it into subtasks and assign each to the best agent.
Available agents: orchestrator, script, seo, image, research, reply

Respond ONLY with a valid JSON array. No markdown. No explanation. Example:
[
  {"agent": "research", "task": "Research the Mali Empire and Mansa Musa's wealth"},
  {"agent": "script",   "task": "Write a 6-minute YouTube script about Mansa Musa using this hook: The richest man in history wasn't a tech billionaire"},
  {"agent": "seo",      "task": "Generate viral titles, description, and tags for a Mansa Musa YouTube video"},
  {"agent": "image",    "task": "Generate thumbnail prompts for Mansa Musa video — gold, Mali Empire, cinematic"}
]
"""

def _groq(system: str, user: str, max_tokens: int = 1024) -> str:
    r = requests.post(
        "https://api.groq.com/openai/v1/chat/completions",
        headers={
            "Authorization": f"Bearer {GROQ_API_KEY}",
            "Content-Type": "application/json"
        },
        json={
            "model": GROQ_MODEL,
            "messages": [
                {"role": "system", "content": system},
                {"role": "user",   "content": user}
            ],
            "max_tokens": max_tokens
        },
        timeout=45
    )
    r.raise_for_status()
    return r.json()["choices"][0]["message"]["content"].strip()

def process_task(task: str, agent: str = "orchestrator") -> str:
    persona = AGENT_PERSONAS.get(agent, AGENT_PERSONAS["orchestrator"])
    return _groq(persona, task, max_tokens=1200)

def orchestrate_task(task: str) -> str:
    """Returns JSON string: [{agent, task}, ...]"""
    raw = _groq(ORCHESTRATOR_SYSTEM, task, max_tokens=800)
    # Strip any accidental markdown fences
    raw = raw.replace("```json", "").replace("```", "").strip()
    # Validate it's parseable
    json.loads(raw)
    return raw